<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Mealora Plan requests NO permissions of any kind.
      No INTERNET, camera, notifications, location, microphone, storage,
      contacts, calendar, or alarm permissions are declared. The app works
      fully offline using local on-device storage only.
    -->

    <application
        android:name=".MealoraApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MealoraPlan.Starting">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="portrait"
            android:configChanges="uiMode|keyboardHidden|keyboard|orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.MealoraPlan.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
