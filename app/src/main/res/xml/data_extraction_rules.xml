<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules (Android 12+). Local DataStore only; nothing is sent
   off-device by the app itself.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
